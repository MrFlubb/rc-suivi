rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'level', 'slotIndex']) &&
             data.name is string && data.name.size() > 0 &&
             data.level in ['FER', 'BRONZE', 'ARGENT', 'OR'] &&
             data.slotIndex is number &&
             (!('description' in data) || (data.description is string && data.description.size() <= 5000));
    }

    match /students/{studentId} {
      allow read: if true; // Public view for this specific app use-case, or restricted to signed in
      allow write: if true; // Since we don't have auth enforced yet in the prompt, but standard is restricted
    }
  }
}
